{
  "name": "website",
  "version": "0.0.1",
  "private": true,
  "homepage": "http://hypixelts.github.io/website",
  "scripts": {
    "docusaurus": "docusaurus",
    "start": "docusaurus start",
    "build": "docusaurus build",
    "swizzle": "docusaurus swizzle",
    "clear": "docusaurus clear",
    "serve": "docusaurus serve",
    "write-translations": "docusaurus write-translations",
    "write-heading-ids": "docusaurus write-heading-ids",
    "typecheck": "tsc",
    "lint": "eslint src --ext ts --fix",
    "lint:md": "markdownlint-cli2 .",
    "format": "prettier --write \"{src, static, docs}/**/*.{ts,tsx,css,md}\"",
    "update": "yarn upgrade-interactive",
    "prepare": "husky install",
    "update-submodules": "git pull --recurse-submodule && git submodule update --remote --recursive",
    "predeploy": "yarn build",
    "deploy": "gh-pages -d build"
  },
  "dependencies": {
    "@docusaurus/core": "2.0.0-beta.14",
    "@docusaurus/preset-classic": "2.0.0-beta.14",
    "@mdx-js/react": "^1.6.21",
    "@sapphire/docusaurus-plugin-npm2yarn2pnpm": "^1.0.3",
    "@sapphire/docusaurus-plugin-ts2esm2cjs": "^1.0.3",
    "clsx": "^1.1.1",
    "prism-react-renderer": "^1.2.1",
    "react": "^17.0.1",
    "react-dom": "^17.0.1",
    "swr": "^1.1.2"
  },
  "devDependencies": {
    "@commitlint/cli": "^16.0.2",
    "@commitlint/config-conventional": "^16.0.0",
    "@docusaurus/module-type-aliases": "2.0.0-beta.14",
    "@sapphire/eslint-config": "^4.0.9",
    "@sapphire/prettier-config": "^1.2.8",
    "@sapphire/ts-config": "^3.1.7",
    "@types/eslint": "^8",
    "@types/gh-pages": "^3",
    "@types/node": "^17.0.8",
    "@types/react": "^17.0.38",
    "@types/react-dom": "^17.0.11",
    "@typescript-eslint/eslint-plugin": "^5.9.1",
    "@typescript-eslint/parser": "^5.9.1",
    "docusaurus-plugin-typedoc": "^0.16.7",
    "eslint": "8.6.0",
    "eslint-config-prettier": "^8.3.0",
    "eslint-plugin-import": "^2.25.4",
    "eslint-plugin-jsx-a11y": "^6.5.1",
    "eslint-plugin-prettier": "^4.0.0",
    "eslint-plugin-react": "^7.28.0",
    "eslint-plugin-react-hooks": "^4.3.0",
    "gh-pages": "^3.2.3",
    "husky": "^7.0.4",
    "lint-staged": "^12.1.7",
    "markdownlint": "^0.25.1",
    "markdownlint-cli2": "^0.3.2",
    "prettier": "^2.5.1",
    "typedoc": "^0.22.10",
    "typedoc-plugin-markdown": "^3.11.11",
    "typescript": "^4.5.4"
  },
  "browserslist": {
    "production": [
      ">0.5%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/hypixelts/website.git"
  },
  "commitlint": {
    "extends": [
      "@commitlint/config-conventional"
    ],
    "rules": {
      "subject-full-stop": [
        0
      ]
    }
  },
  "lint-staged": {
    "*.{mjs,js,jsx,ts,tsx}": "yarn lint"
  },
  "config": {
    "commitizen": {
      "path": "./node_modules/cz-conventional-changelog"
    }
  },
  "packageManager": "yarn@3.1.1"
}
